# Hackathon Hunter — Environment Variables Template
# Copy to .env and fill in your real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------
# Gmail SMTP (App Password required — NOT your main Gmail password)
# Steps: Google Account → Security → 2-Step Verification → App Passwords
# ---------------------------------------------------------------
HH_EMAIL_ENABLED=false
HH_EMAIL_SENDER=your.gmail@gmail.com
HH_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
HH_EMAIL_RECIPIENTS=recipient@example.com

# ---------------------------------------------------------------
# Optional overrides (leave blank to use defaults)
# ---------------------------------------------------------------
# HH_EMAIL_SMTP_HOST=smtp.gmail.com
# HH_EMAIL_SMTP_PORT=587
# HH_EMAIL_SUBJECT_PREFIX=[Hackathon Hunter]
# HH_DATABASE_PATH=data/hackathons.db
# HH_LOG_LEVEL=INFO

# ---------------------------------------------------------------
# Location Filtering
# ---------------------------------------------------------------
# HH_LOCATION_FILTER=india   # india (default) / all (disable filtering)
# HH_INCLUDE_ONLINE=true     # true (default) / false
# HH_PRIORITY_CITY=hyderabad # hyderabad (default)

